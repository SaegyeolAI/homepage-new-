# SMTP 설정 — .env 파일로 복사 후 실제 값으로 교체하세요
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

PORT=3000

# Rate limit — Upstash Redis (https://console.upstash.com → Redis 데이터베이스 생성 후 REST 정보 복사)
# 둘 다 비우면 rate limit이 비활성화됩니다(운영 배포 전 반드시 설정).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
